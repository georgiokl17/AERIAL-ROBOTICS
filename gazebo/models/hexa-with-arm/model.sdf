<?xml version="1.0" ?>

<sdf version="1.5">
  <model name="hexa-with-arm">
    <link name="base">
      <inertial>
        <mass>2.3</mass>
        <inertia>
          <ixx>0.0115</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.0114</iyy><iyz>0</iyz>
          <izz>0.0194</izz>
        </inertia>
      </inertial>
      
  
      <collision name="base">
	<pose>0 0 -0.05 0 0 0</pose>
        <geometry>
          <cylinder><radius>0.1354</radius><length>0.15</length></cylinder>
        </geometry>
      </collision>
      <!-- three spheres to make contact stable -->
      <collision name="land_1">
        <pose>0.2 0 -0.21 0 0 0</pose>
        <geometry>
          <sphere><radius>0.03</radius></sphere>
        </geometry>
      </collision>
      <collision name="land_2">
        <pose>-0.1 0.173 -0.21 0 0 0</pose>
        <geometry>
          <sphere><radius>0.03</radius></sphere>
        </geometry>
      </collision>
      <collision name="land_3">
        <pose>-0.1 -0.173 -0.21 0 0 0</pose>
        <geometry>
          <sphere><radius>0.03</radius></sphere>
        </geometry>
      </collision>

      <visual name="body">
        <geometry>
          <cylinder><radius>0.1354</radius><length>0.05</length></cylinder>
        </geometry>
        <material>
          <ambient>0.4 0.6 1.0 1</ambient>
          <diffuse>0.4 0.6 1.0 1</diffuse>
        </material>
      </visual>

      <visual name="lander-1">
        <pose>0.1025 0.1776 -0.11 3.1416 -0.1736 1.0472</pose>
        <geometry>
          <cylinder><radius>0.01</radius><length>0.25</length></cylinder>
        </geometry>
        <material>
          <ambient>0 0 0 1.0</ambient>
          <diffuse>0 0 0 1.0</diffuse>
        </material>
      </visual>

      <visual name="lander-2">
        <pose>-0.1025 0.1776 -0.11 3.1416 -0.1736 2.0944</pose>
        <geometry>
          <cylinder><radius>0.01</radius><length>0.25</length></cylinder>
        </geometry>
        <material>
          <ambient>0 0 0 1.0</ambient>
          <diffuse>0 0 0 1.0</diffuse>
        </material>
      </visual>

      <visual name="lander-3">
       <pose>-0.1025 -0.1776 -0.11 3.1416 0.1736 1.0472</pose>
        <geometry>
          <cylinder><radius>0.01</radius><length>0.25</length></cylinder>
        </geometry>
        <material>
          <ambient>0 0 0 1.0</ambient>
          <diffuse>0 0 0 1.0</diffuse>
        </material>
      </visual>

      <visual name="lander-4">
        <pose>0.1025 -0.1776 -0.11 3.1416 0.1736 2.0944</pose>
        <geometry>
          <cylinder><radius>0.01</radius><length>0.25</length></cylinder>
        </geometry>
        <material>
          <ambient>0 0 0 1.0</ambient>
          <diffuse>0 0 0 1.0</diffuse>
        </material>
      </visual>


      <visual name="arm-1">
        <pose>0.2150 0 0 0 1.5708 0</pose>
        <geometry>
          <cylinder><radius>0.01</radius><length>0.38998</length></cylinder>
        </geometry>
        <material>
          <ambient>1.0 0.2 0.2 1.0</ambient>
          <diffuse>1.0 0.2 0.2 1.0</diffuse>
        </material>
      </visual>
      <visual name="arm-2">
        <pose>0.1025 0.1776 0 0 1.5708 1.0472</pose>
        <geometry>
          <cylinder><radius>0.01</radius><length>0.40998</length></cylinder>
        </geometry>
        <material>
          <ambient>0.6 0.6 0.6 1</ambient>
          <diffuse>0.6 0.6 0.6 1</diffuse>
        </material>
      </visual>
      <visual name="arm-3">
        <pose>-0.1025 0.1776 0 0 1.5708 2.0944</pose>
        <geometry>
          <cylinder><radius>0.01</radius><length>0.40998</length></cylinder>
        </geometry>
        <material>
          <ambient>0.6 0.6 0.6 1</ambient>
          <diffuse>0.6 0.6 0.6 1</diffuse>
        </material>
      </visual>
      <visual name="arm-4">
        <pose>-0.2150 0 0 0 1.5708 0</pose>
        <geometry>
          <cylinder><radius>0.01</radius><length>0.38998</length></cylinder>
        </geometry>
        <material>
          <ambient>0.6 0.6 0.6 1</ambient>
          <diffuse>0.6 0.6 0.6 1</diffuse>
        </material>
      </visual>
      <visual name="arm-5">
        <pose>-0.1025 -0.1776 0 0 1.5708 -2.0944</pose>
        <geometry>
          <cylinder><radius>0.01</radius><length>0.40998</length></cylinder>
        </geometry>
        <material>
          <ambient>0.6 0.6 0.6 1</ambient>
          <diffuse>0.6 0.6 0.6 1</diffuse>
        </material>
      </visual>
      <visual name="arm-6">
        <pose>0.1025 -0.1776 0 0 1.5708 -1.0472</pose>
        <geometry>
          <cylinder><radius>0.01</radius><length>0.40998</length></cylinder>
        </geometry>
        <material>
          <ambient>0.6 0.6 0.6 1</ambient>
          <diffuse>0.6 0.6 0.6 1</diffuse>
        </material>
      </visual>
    </link>

    <include>
      <uri>model://mrsim-rotor</uri>
      <name>rotor-1</name>
      <pose>0.38998 0 0 2.7925 -0.3491 0</pose>
    </include>
    <joint name="motor-1" type="revolute">
      <parent>base</parent>
      <child>rotor-1::propeller</child>
      <axis><xyz>0 0 -1</xyz></axis>
    </joint>

    <include>
      <uri>model://mrsim-rotor</uri>
      <name>rotor-2</name>
      <pose>0.195 0.3377 0 -2.7925 -0.3491 1.0472</pose>
    </include>
    <joint name="motor-2" type="revolute">
      <parent>base</parent>
      <child>rotor-2::propeller</child>
      <axis><xyz>0 0 -1</xyz></axis>
    </joint>

    <include>
      <uri>model://mrsim-rotor</uri>
      <name>rotor-3</name>
      <pose>-0.195 0.3377 0 2.7925 -0.3491 2.0944</pose>
    </include>
    <joint name="motor-3" type="revolute">
      <parent>base</parent>
      <child>rotor-3::propeller</child>
      <axis><xyz>0 0 -1</xyz></axis>
    </joint>

    <include>
      <uri>model://mrsim-rotor</uri>
      <name>rotor-4</name>
      <pose>-0.38998 0 0 -3.4907 0.3491 0</pose>
    </include>
    <joint name="motor-4" type="revolute">
      <parent>base</parent>
      <child>rotor-4::propeller</child>
      <axis><xyz>0 0 -1</xyz></axis>
    </joint>

    <include>
      <uri>model://mrsim-rotor</uri>
      <name>rotor-5</name>
      <pose>-0.195 -0.3377 0 -2.7925 0.3491 1.0472</pose>
    </include>
    <joint name="motor-5" type="revolute">
      <parent>base</parent>
      <child>rotor-5::propeller</child>
      <axis><xyz>0 0 -1</xyz></axis>
    </joint>

    <include>
      <uri>model://mrsim-rotor</uri>
      <name>rotor-6</name>
      <pose>0.195 -0.3377 0 2.7925 0.3491 2.0944</pose>
    </include>
    <joint name="motor-6" type="revolute">
      <parent>base</parent>
      <child>rotor-6::propeller</child>
      <axis><xyz>0 0 -1</xyz></axis>
    </joint>

    <plugin name="mrsim" filename="mrsim-gazebo.so">
      <link>base</link>

      <rotors>
        <noise>0.03</noise>
        <cf>9.9016e-4</cf>
        <ct>1.9e-5</ct>
        <vfxy>0.5</vfxy><vfz>0.5</vfz>
        <vtxy>0.5</vtxy><vtz>0.5</vtz>

        <rotor><joint spin="cw">motor-1</joint></rotor>
        <rotor><joint spin="ccw">motor-2</joint></rotor>
        <rotor><joint spin="cw">motor-3</joint></rotor>
        <rotor><joint spin="ccw">motor-4</joint></rotor>
        <rotor><joint spin="cw">motor-5</joint></rotor>
        <rotor><joint spin="ccw">motor-6</joint></rotor>
      </rotors>
    </plugin>
    
    <link name="link1">
    <pose>0 0 -0.075 0 0 0</pose> 
    <inertial>
      <mass>0.1</mass>
      <inertia>
        <ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz>
        <iyy>0.001</iyy><iyz>0</iyz>
        <izz>0.001</izz>
      </inertia>
    </inertial>

    <collision name="link1_collision">
      <geometry><cylinder><radius>0.02</radius><length>0.1</length></cylinder></geometry>
    </collision>
    
    <visual name="link1_visual">
      <geometry><cylinder><radius>0.02</radius><length>0.1</length></cylinder></geometry>
      <material><ambient>1 0 0 1</ambient></material> </visual>
  </link>

  <link name="link2">
    <pose>0 0.15 -0.125 1.57 0 0</pose>
    <inertial>
      <mass>0.1</mass>
      <inertia>
        <ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz>
        <iyy>0.001</iyy><iyz>0</iyz>
        <izz>0.001</izz>
      </inertia>
    </inertial>
    <collision name="link2_collision">
      <geometry><cylinder><radius>0.02</radius><length>0.3</length></cylinder></geometry>
    </collision>
    <visual name="link2_visual">
      <geometry><cylinder><radius>0.02</radius><length>0.3</length></cylinder></geometry>
      <material><ambient>0 1 0 1</ambient></material> </visual>
  </link>

  <joint name="joint1" type="fixed">
    <parent>base</parent>
    <child>link1</child>
  </joint> 

  <joint name="joint2" type="revolute">
    <parent>link1</parent>
    <child>link2</child>
    <pose>0 0 0.15 0 0 0</pose> 
    <axis>
      <xyz>1 0 0</xyz>
      <limit>
        <lower>-1.57</lower> <upper>1.57</upper>
      </limit>
      <dynamics>
        <damping>0.5</damping>
        <friction>0.05</friction>
      </dynamics>
    </axis>
  </joint>
  

  <link name="gripper">    
    <pose>0 0.3so  -0.125 1.57 0 3.14159</pose> 
    <inertial>
      <mass>0.05</mass>
      <inertia>
        <ixx>0.0001</ixx><ixy>0</ixy><ixz>0</ixz>
        <iyy>0.0001</iyy><iyz>0</iyz>
        <izz>0.0001</izz>
      </inertia>
    </inertial>
    <collision name="gripper_base_collision">
      <pose>0 0 0 0 1.5708 0</pose>
      <geometry><cylinder><radius>0.01</radius><length>0.1</length></cylinder></geometry>
    </collision>
    <collision name="finger_left_collision">
      <pose>0.05 0 0.03 0 0 0</pose>
      <geometry><cylinder><radius>0.005</radius><length>0.06</length></cylinder></geometry>
    </collision>
    <collision name="finger_right_collision">
      <pose>-0.05 0 0.03 0 0 0</pose>
      <geometry><cylinder><radius>0.005</radius><length>0.06</length></cylinder></geometry>
    </collision>
    
    <visual name="gripper_base">
      <pose>0 0 0 0 1.5708 0</pose>
      <geometry>
        <cylinder><radius>0.01</radius><length>0.1</length></cylinder>
      </geometry>
      <material><ambient>0.5 0.5 0.5 1</ambient></material>
    </visual>

    <visual name="finger_left">
      <pose>0.05 0 0.03 0 0 0</pose>
      <geometry>
        <cylinder><radius>0.005</radius><length>0.06</length></cylinder>
      </geometry>
      <material><ambient>0.5 0.5 0.5 1</ambient></material>
    </visual>

    <visual name="finger_right">
      <pose>-0.05 0 0.03 0 0 0</pose>
      <geometry>
        <cylinder><radius>0.005</radius><length>0.06</length></cylinder>
      </geometry>
      <material><ambient>0.5 0.5 0.5 1</ambient></material>
    </visual>
  </link>

  <joint name="gripper_joint" type="fixed">
    <parent>link2</parent>
    <child>gripper</child>
    <pose>0 0 -0.05 0 0 0</pose>
  </joint>
  
</model>
</sdf>